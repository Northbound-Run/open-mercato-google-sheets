{
  "name": "@northbound-run/sync-google-sheets",
  "version": "0.1.0",
  "description": "Google Sheets ↔ Open Mercato Data Sync adapter: production-ready import, plus experimental scheduled sync and bidirectional export. Entity-agnostic and reusable — not tied to any specific project.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "license": "MIT",
  "author": "Northbound",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Northbound-Run/open-mercato-google-sheets.git"
  },
  "bugs": {
    "url": "https://github.com/Northbound-Run/open-mercato-google-sheets/issues"
  },
  "homepage": "https://github.com/Northbound-Run/open-mercato-google-sheets#readme",
  "keywords": [
    "open-mercato",
    "google-sheets",
    "data-sync",
    "oauth",
    "integration",
    "bidirectional-sync",
    "etl"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "node build.mjs",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit",
    "prepack": "node build.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*.ts": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "./*.tsx": {
      "types": "./src/*.tsx",
      "default": "./dist/*.js"
    },
    "./*.json": "./src/*.json",
    "./*": {
      "types": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "default": "./dist/*.js"
    },
    "./*/*.json": "./src/*/*.json",
    "./*/*": {
      "types": [
        "./src/*/*.ts",
        "./src/*/*.tsx"
      ],
      "default": "./dist/*/*.js"
    },
    "./*/*/*.json": "./src/*/*/*.json",
    "./*/*/*": {
      "types": [
        "./src/*/*/*.ts",
        "./src/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*.js"
    },
    "./*/*/*/*.json": "./src/*/*/*/*.json",
    "./*/*/*/*": {
      "types": [
        "./src/*/*/*/*.ts",
        "./src/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*.js"
    },
    "./*/*/*/*/*.json": "./src/*/*/*/*/*.json",
    "./*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*.ts",
        "./src/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*.js"
    },
    "./*/*/*/*/*/*.json": "./src/*/*/*/*/*/*.json",
    "./*/*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*/*.ts",
        "./src/*/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*/*.js"
    }
  },
  "dependencies": {
    "@open-mercato/core": "0.6.5",
    "@open-mercato/ui": "0.6.5"
  },
  "peerDependencies": {
    "@mikro-orm/postgresql": "^7.0.14",
    "@open-mercato/shared": "0.6.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@mikro-orm/core": "^7.0.14",
    "@mikro-orm/decorators": "^7.0.14",
    "@mikro-orm/migrations": "^7.0.14",
    "@mikro-orm/postgresql": "^7.0.14",
    "@open-mercato/shared": "0.6.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "awilix": "^12.1.1",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
